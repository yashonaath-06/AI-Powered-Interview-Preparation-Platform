# ============================================================
#  GLOBAL ENVIRONMENT TEMPLATE
#  Copy this file to .env and fill in real values.
#  NEVER commit the real .env to GitHub.
# ============================================================

# ---- Database ----
POSTGRES_USER=interview_admin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=interview_prep
DATABASE_URL=postgresql+psycopg2://interview_admin:change_me_strong_password@db:5432/interview_prep

# ---- Backend ----
BACKEND_PORT=8000
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000

# ---- AI keys (optional, free fallbacks exist) ----
GROQ_API_KEY=
OPENAI_API_KEY=
HUGGINGFACE_TOKEN=

# ---- Whisper STT model (Phase 8) ----
WHISPER_MODEL=tiny.en

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000


# ---- Admin (Phase 12) ----
# Comma-separated list of emails auto-promoted to admin on signup.
# Or run: python -m app.cli make-admin you@example.com
ADMIN_EMAILS=
