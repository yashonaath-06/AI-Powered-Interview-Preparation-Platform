# ============================================================
#  Backend-only environment template.
#  Copy to backend/.env (or use the project-root .env via docker)
# ============================================================

# DB — use sqlite locally if you don't want to install postgres
DATABASE_URL=sqlite:///./interview_prep.db
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/interview_prep

# Auth
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
CORS_ORIGINS=http://localhost:3000

# AI keys (optional)
GROQ_API_KEY=
OPENAI_API_KEY=
HUGGINGFACE_TOKEN=

# Whisper STT (Phase 8). Options: tiny.en | base.en | small.en | medium.en
# tiny.en  -> fastest, ~75MB,  ~32x realtime on CPU
# base.en  -> better quality, ~145MB
# small.en -> recommended for production, ~465MB
WHISPER_MODEL=tiny.en
